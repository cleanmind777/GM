{
  "name": "gm",
  "version": "1.0.0",
  "private": true,
  "description": "Local LAN video calls: mediasoup SFU + Socket.IO signaling",
  "main": "server/index.js",
  "scripts": {
    "build:client": "esbuild public/app.js --bundle --outfile=public/app.bundle.js --format=esm --platform=browser",
    "postinstall": "npm run build:client",
    "start": "node server/index.js",
    "dev": "npm run build:client && node server/index.js"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "mediasoup": "^3.14.14",
    "mediasoup-client": "^3.7.6",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "esbuild": "^0.24.2"
  }
}
