# Copy this file to `.env` in the project root and adjust values.
# `npm start` loads `.env` automatically (via dotenv).

# HTTP port for Express + Socket.IO (default 3000).
# Still overridden by a CLI argument if you pass one: npm start -- 3001
PORT=3000

# LAN IPv4 of this machine for mediasoup ICE candidates.
# Use when other devices on your network open http://<this-ip>:PORT — set to that same IP.
# Find it with `ipconfig` (Windows) or `ip addr` (Linux). Example: 192.168.1.10
# For browser-only on this PC, 127.0.0.1 is fine.
MEDIASOUP_ANNOUNCED_IP=127.0.0.1

# Optional: serve HTTPS alongside HTTP (camera/mic on LAN IPs need https://).
# Paths can be absolute or relative to the project directory.
# HTTPS_PORT=3443
# SSL_KEY_PATH=
# SSL_CERT_PATH=
# SSL_CA_PATH=
